<div class="min-h-screen relative overflow-hidden flex flex-col bg-blush">

  <!-- Blobs -->
  <div class="blob" style="background-color: hsl(215,60%,78%); width:220px; height:220px; top:-60px; left:-60px;"></div>
  <div class="blob" style="background-color: hsl(12,70%,75%); width:240px; height:240px; top:-80px; right:-80px;"></div>
  <div class="blob" style="background-color: hsl(12,70%,75%); width:240px; height:240px; bottom:-80px; left:-80px;"></div>
  <div class="blob" style="background-color: hsl(215,60%,78%); width:220px; height:220px; bottom:-60px; right:-60px;"></div>

  <!-- Navbar -->
  <nav class="relative z-10 flex justify-between items-center px-8 py-5">
    <span class="text-lg font-semibold text-coral-deep" style="font-family: 'DM Serif Display', serif;">YT · Feedback</span>
    <%= link_to "History →", analyses_path, class: "text-sm font-semibold tracking-wide", style: "color: hsl(240,35%,25%);" %>
  </nav>

  <!-- Main content -->
  <div class="relative z-10 flex-1 flex flex-col items-center justify-center text-center px-6 py-8">

    <h1 class="mb-3 leading-tight text-gradient-coral" style="font-size: clamp(2.4rem, 5vw, 3.8rem);">
      YouTube Feedback<br>Analyzer
    </h1>

    <p class="mb-4 italic text-lg text-lavender" style="font-family: 'DM Serif Display', serif;">
      AI-Powered Product Intelligence
    </p>

    <p class="mb-8 text-base max-w-lg text-muted-soft">
      Paste a YouTube URL and turn raw comments into the pain points your users actually care about.
    </p>

    <%= form_with model: @analysis, class: "w-full max-w-xl", id: "analysis-form" do |f| %>
      <% if @analysis.errors.any? %>
        <div class="rounded-2xl p-3 mb-4 text-sm text-red-700 bg-red-50">
          <%= @analysis.errors.full_messages.first %>
        </div>
      <% end %>

      <div class="flex gap-3 items-center">
        <%= f.text_field :video_url,
            placeholder: "https://youtube.com/watch?v=...",
            class: "flex-1 px-5 py-3 rounded-full shadow-sm text-gray-700 focus:outline-none focus:ring-2 border-0",
            style: "background: white;" %>
        <%= f.submit "Analyze",
            class: "px-7 py-3 rounded-full text-white font-semibold cursor-pointer hover:opacity-90 transition-opacity shrink-0 bg-coral-deep" %>
      </div>
    <% end %>

    <!-- Loading overlay -->
    <div id="loading-overlay" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background-color: hsl(12,60%,95%);">
      <div class="max-w-sm w-full text-center space-y-8 px-6">
        <div class="space-y-3">
          <div class="text-4xl" id="loading-emoji">🔍</div>
          <h2 class="text-2xl" style="font-family:'DM Serif Display',serif; color:hsl(240,35%,25%)">Analyzing Comments</h2>
          <p class="text-sm text-muted-soft">Hang tight — your report is on its way.</p>
        </div>

        <!-- Progress bar -->
        <div class="w-full h-2 rounded-full overflow-hidden" style="background-color:hsl(12,40%,88%)">
          <div id="progress-bar" class="h-full rounded-full transition-all duration-700" style="width:0%; background-color:hsl(350,75%,55%)"></div>
        </div>

        <!-- Steps -->
        <div class="space-y-3 text-left" id="steps-list">
          <% [
            "Fetching comments from YouTube…",
            "Analyzing sentiment patterns…",
            "Clustering pain points with AI…",
            "Generating insights report…"
          ].each_with_index do |step, i| %>
            <div class="step-item flex items-center gap-3 text-sm opacity-40 transition-all duration-300" data-index="<%= i %>">
              <span class="step-dot w-6 h-6 rounded-full flex items-center justify-center text-xs font-semibold shrink-0 border" style="border-color:hsl(350,75%,55%); color:hsl(350,75%,55%)">
                <%= i + 1 %>
              </span>
              <span class="step-text" style="color:hsl(240,35%,25%)"><%= step %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener("turbo:submit-start", function(e) {
        if (e.target.id !== "analysis-form") return;

        const overlay = document.getElementById("loading-overlay");
        const progressBar = document.getElementById("progress-bar");
        const steps = document.querySelectorAll(".step-item");
        const emojis = ["🔍", "🧠", "✨", "📊"];
        const emojiEl = document.getElementById("loading-emoji");

        overlay.classList.remove("hidden");
        let current = 0;

        function activateStep(i) {
          steps.forEach((s, idx) => {
            const dot = s.querySelector(".step-dot");
            if (idx < i) {
              s.style.opacity = "1";
              dot.textContent = "✓";
              dot.style.backgroundColor = "hsl(350,75%,55%)";
              dot.style.color = "white";
              dot.style.borderColor = "hsl(350,75%,55%)";
            } else if (idx === i) {
              s.style.opacity = "1";
            } else {
              s.style.opacity = "0.4";
            }
          });
          progressBar.style.width = ((i + 1) / steps.length * 100) + "%";
          if (emojiEl && emojis[i]) emojiEl.textContent = emojis[i];
        }

        activateStep(0);
        const interval = setInterval(function() {
          current++;
          if (current < steps.length) {
            activateStep(current);
          } else {
            clearInterval(interval);
          }
        }, 8000);
      });
    </script>

    <div class="mt-8 flex items-center gap-4 text-xs font-semibold tracking-widest text-muted-soft">
      <span>500+ COMMENTS ANALYZED</span>
      <span>·</span>
      <span>PAIN POINTS & FEATURES</span>
      <span>·</span>
      <span>PM RECOMMENDATIONS</span>
    </div>

  </div>

  <p class="relative z-10 text-right px-8 pb-5 text-xs font-semibold tracking-widest text-muted-soft">
    BY INES KACI · PRODUCT MANAGER
  </p>

</div>
