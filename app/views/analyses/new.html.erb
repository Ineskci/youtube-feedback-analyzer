<div class="min-h-screen bg-gray-50 flex items-center justify-center">
  <div class="bg-white p-8 rounded-xl shadow-md w-full max-w-lg">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">YouTube Feedback Analyzer</h1>
    <p class="text-gray-500 mb-6">Colle l'URL d'une vidéo YouTube pour analyser ses commentaires.</p>

    <%= form_with model: @analysis, url: analyses_path, data: { turbo: false } do |f| %>
      <% if @analysis.errors.any? %>
        <div class="bg-red-50 text-red-700 p-3 rounded mb-4">
          <%= @analysis.errors.full_messages.first %>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :video_url, "URL de la vidéo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :video_url, placeholder: "https://www.youtube.com/watch?v=...",
            class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500" %>
      </div>

      <%= f.submit "Analyser les commentaires →",
          class: "w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg cursor-pointer",
          data: { disable_with: "Analyse en cours..." } %>
    <% end %>
  </div>
</div>
