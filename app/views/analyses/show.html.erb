<div class="min-h-screen bg-gray-50 p-8">
  <div class="max-w-3xl mx-auto">
    <div class="mb-6">
      <%= link_to "← Nouvelle analyse", new_analysis_path, class: "text-red-600 hover:underline text-sm" %>
    </div>

    <!-- Header -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-6">
      <h1 class="text-xl font-bold text-gray-900 mb-1">Résultats de l'analyse</h1>
      <p class="text-gray-500 text-sm">
        <%= @analysis.comments_array.size %> commentaires analysés •
        <a href="<%= @analysis.video_url %>" target="_blank" class="text-red-600 hover:underline">Voir la vidéo</a>
      </p>
    </div>

    <% ai = @analysis.ai_analysis_hash %>

    <% if ai.present? %>
      <!-- Résumé exécutif -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-2">Résumé exécutif</h2>
        <p class="text-gray-700"><%= ai["summary"] %></p>
      </div>

      <!-- Sentiment -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Sentiment global</h2>
        <div class="flex gap-4 text-center">
          <div class="flex-1 bg-green-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-green-600"><%= ai.dig("sentiment", "positive") %>%</p>
            <p class="text-sm text-gray-500">Positif</p>
          </div>
          <div class="flex-1 bg-gray-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-gray-500"><%= ai.dig("sentiment", "neutral") %>%</p>
            <p class="text-sm text-gray-500">Neutre</p>
          </div>
          <div class="flex-1 bg-red-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-red-500"><%= ai.dig("sentiment", "negative") %>%</p>
            <p class="text-sm text-gray-500">Négatif</p>
          </div>
        </div>
      </div>

      <!-- Pain Points -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Top Pain Points</h2>
        <ul class="space-y-3">
          <% ai["pain_points"]&.each do |point| %>
            <li class="flex justify-between items-start border-b border-gray-100 pb-3">
              <div>
                <p class="font-medium text-gray-800"><%= point["title"] %></p>
                <p class="text-sm text-gray-500"><%= point["description"] %></p>
              </div>
              <span class="text-sm bg-red-100 text-red-700 px-2 py-1 rounded-full ml-4 whitespace-nowrap">
                <%= point["count"] %> mentions
              </span>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Feature Requests -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Feature Requests</h2>
        <ul class="space-y-3">
          <% ai["feature_requests"]&.each do |req| %>
            <li class="flex justify-between items-start border-b border-gray-100 pb-3">
              <div>
                <p class="font-medium text-gray-800"><%= req["title"] %></p>
                <p class="text-sm text-gray-500"><%= req["description"] %></p>
              </div>
              <span class="text-sm bg-blue-100 text-blue-700 px-2 py-1 rounded-full ml-4 whitespace-nowrap">
                <%= req["votes"] %> votes
              </span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Commentaires bruts -->
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="font-semibold text-gray-700 mb-4">Commentaires bruts (<%= @analysis.comments_array.size %>)</h2>
      <ul class="space-y-3">
        <% @analysis.comments_array.each do |comment| %>
          <li class="border-b border-gray-100 pb-3 text-sm text-gray-700"><%= comment %></li>
        <% end %>
      </ul>
    </div>

  </div>
</div>
