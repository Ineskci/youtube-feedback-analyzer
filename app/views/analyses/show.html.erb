<div class="min-h-screen bg-gray-50 p-8">
  <div class="max-w-3xl mx-auto">
    <div class="flex gap-4 mb-6">
      <%= link_to "← New analysis", new_analysis_path, class: "text-red-600 hover:underline text-sm" %>
      <%= link_to "History", analyses_path, class: "text-gray-400 hover:underline text-sm" %>
    </div>

    <!-- Header -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-6">
      <div class="flex gap-4 items-start">
        <% if @analysis.video_thumbnail.present? %>
          <img src="<%= @analysis.video_thumbnail %>" alt="Video thumbnail"
               class="w-32 h-20 object-cover rounded-lg shrink-0">
        <% end %>
        <div>
          <h1 class="text-xl font-bold text-gray-900 mb-1">
            <%= @analysis.video_title.presence || "Analysis Results" %>
          </h1>
          <p class="text-gray-500 text-sm">
            <% if @analysis.channel_name.present? %>
              <%= @analysis.channel_name %> •
            <% end %>
            <%= @analysis.comments_array.size %> comments analyzed •
            <a href="<%= @analysis.video_url %>" target="_blank" class="text-red-600 hover:underline">View video</a>
          </p>
        </div>
      </div>
    </div>

    <% ai = @analysis.ai_analysis_hash %>

    <% if ai.present? %>
      <!-- Executive Summary -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-2">Executive Summary</h2>
        <p class="text-gray-700"><%= ai["summary"] %></p>
      </div>

      <!-- Recommended Actions -->
      <% if ai["recommended_actions"].present? %>
        <%
          groups = {
            "sprint_1"     => { label: "Immediate Priorities — Sprint 1", color: "red" },
            "sprint_2"     => { label: "Quick Wins — Sprint 2", color: "yellow" },
            "strategic"    => { label: "Strategic Initiatives", color: "blue" },
            "deprioritize" => { label: "Deprioritize", color: "gray" }
          }
          actions_by_group = ai["recommended_actions"].group_by { |a| a["group"] || "sprint_1" }
        %>
        <div class="bg-white rounded-xl shadow-md p-6 mb-6">
          <h2 class="font-semibold text-gray-800 mb-5">Recommended Actions</h2>
          <% groups.each do |group_key, group_meta| %>
            <% group_actions = actions_by_group[group_key]; next if group_actions.blank? %>
            <div class="mb-5">
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-3"><%= group_meta[:label] %></p>
              <ul class="space-y-3">
                <% group_actions.each_with_index do |action, i| %>
                  <%
                    c = case action["priority"]
                        when "high"   then "red"
                        when "medium" then "yellow"
                        else "gray"
                        end
                  %>
                  <li class="border border-gray-100 rounded-lg p-4">
                    <div class="flex justify-between items-start gap-4 mb-2">
                      <p class="font-medium text-gray-800"><%= action["action"] %></p>
                      <span class="shrink-0 text-xs font-semibold px-2 py-1 rounded-full
                        <%= c == 'red' ? 'bg-red-100 text-red-700' : c == 'yellow' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-500' %>">
                        <%= action["priority"]&.upcase %>
                      </span>
                    </div>
                    <p class="text-sm text-gray-500 mb-2"><%= action["rationale"] %></p>
                    <div class="flex flex-wrap gap-3 text-xs text-gray-400">
                      <% if action["team"].present? %>
                        <span>👥 <%= action["team"] %></span>
                      <% end %>
                      <% if action["timeline"].present? %>
                        <span>⏱️ <%= action["timeline"] %></span>
                      <% end %>
                      <% if action["success_metric"].present? %>
                        <span>📈 <%= action["success_metric"] %></span>
                      <% end %>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% end %>


      <!-- Sentiment -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Overall Sentiment</h2>
        <div class="flex gap-4 text-center">
          <div class="flex-1 bg-green-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-green-600"><%= ai.dig("sentiment", "positive") %>%</p>
            <p class="text-sm text-gray-500">Positive</p>
          </div>
          <div class="flex-1 bg-gray-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-gray-500"><%= ai.dig("sentiment", "neutral") %>%</p>
            <p class="text-sm text-gray-500">Neutral</p>
          </div>
          <div class="flex-1 bg-red-50 rounded-lg p-4">
            <p class="text-2xl font-bold text-red-500"><%= ai.dig("sentiment", "negative") %>%</p>
            <p class="text-sm text-gray-500">Negative</p>
          </div>
        </div>
      </div>

      <!-- Pain Points -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Top Pain Points</h2>
        <div class="space-y-4">
          <% ai["pain_points"]&.each_with_index do |point, i| %>
            <%
              impact = point["business_impact"].to_s.upcase
              impact_color = impact == "HIGH" ? "red" : impact == "MEDIUM" ? "yellow" : "gray"
              severity = point["severity"].to_i
            %>
            <div class="border border-gray-100 rounded-lg p-4">
              <!-- Header row -->
              <div class="flex justify-between items-start gap-4 mb-2">
                <p class="font-semibold text-gray-900">#<%= i + 1 %> <%= point["title"] %></p>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs font-semibold px-2 py-1 rounded-full
                    <%= impact_color == 'red' ? 'bg-red-100 text-red-700' : impact_color == 'yellow' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-500' %>">
                    <%= impact.present? ? "#{impact} impact" : "impact" %>
                  </span>
                </div>
              </div>

              <!-- Stats row -->
              <div class="flex items-center gap-4 mb-3 text-sm">
                <span class="text-gray-500">
                  📊 <%= point["percentage"] %>% · <%= point["count"] %> mentions
                </span>
                <span title="Severity <%= severity %>/10">
                  <% [*1..[(severity/2.0).ceil, 5].min].each do %><span class="text-orange-400 text-xs">🔥</span><% end %>
                  <span class="text-xs text-gray-400"><%= severity %>/10</span>
                </span>
              </div>

              <!-- Description -->
              <p class="text-sm text-gray-500 mb-3"><%= point["description"] %></p>

              <!-- Verbatims -->
              <% if point["verbatims"].present? %>
                <div class="space-y-1 mb-3">
                  <% point["verbatims"].each do |quote| %>
                    <p class="text-xs text-gray-400 italic border-l-2 border-gray-200 pl-2">"<%= quote %>"</p>
                  <% end %>
                </div>
              <% end %>

              <!-- Recommended action -->
              <% if point["recommended_action"].present? %>
                <div class="bg-gray-50 rounded px-3 py-2 text-xs text-gray-600">
                  <span class="font-medium text-gray-700">Action →</span> <%= point["recommended_action"] %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Feature Requests -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-6">
        <h2 class="font-semibold text-gray-800 mb-4">Feature Requests</h2>
        <ul class="space-y-3">
          <% ai["feature_requests"]&.each do |req| %>
            <li class="border-b border-gray-100 pb-4">
              <div class="flex justify-between items-start mb-1">
                <p class="font-medium text-gray-800"><%= req["title"] %></p>
                <div class="flex gap-2 ml-4 shrink-0">
                  <span class="text-sm bg-blue-100 text-blue-700 px-2 py-1 rounded-full whitespace-nowrap">
                    <% if req["percentage"].present? %>
                      <%= req["percentage"] %>% · <%= req["votes"] %> votes
                    <% else %>
                      <%= req["votes"] %> votes
                    <% end %>
                  </span>
                  <% if req["priority"] == "Critical" %>
                    <span class="text-sm bg-red-100 text-red-700 px-2 py-1 rounded-full whitespace-nowrap">Critical</span>
                  <% elsif req["priority"] == "Quick Win" %>
                    <span class="text-sm bg-green-100 text-green-700 px-2 py-1 rounded-full whitespace-nowrap">Quick Win</span>
                  <% else %>
                    <span class="text-sm bg-gray-100 text-gray-600 px-2 py-1 rounded-full whitespace-nowrap">Nice to Have</span>
                  <% end %>
                </div>
              </div>
              <p class="text-sm text-gray-500"><%= req["description"] %></p>
              <p class="text-xs text-gray-400 mt-1">
                <%= req["sentiment"] == "positive" ? "😊" : "😤" %>
                <%= req["sentiment"]&.capitalize %> sentiment
              </p>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Raw comments -->
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="font-semibold text-gray-700 mb-4">Raw Comments (<%= @analysis.comments_array.size %>)</h2>
      <ul class="space-y-3">
        <% @analysis.comments_texts.each do |comment| %>
          <li class="border-b border-gray-100 pb-3 text-sm text-gray-700"><%= comment %></li>
        <% end %>
      </ul>
    </div>

  </div>
</div>
