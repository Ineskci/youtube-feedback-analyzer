<div class="min-h-screen bg-gray-50 p-8">
  <div class="max-w-3xl mx-auto">
    <div class="mb-6">
      <%= link_to "← Nouvelle analyse", new_analysis_path, class: "text-red-600 hover:underline text-sm" %>
    </div>

    <div class="bg-white rounded-xl shadow-md p-6 mb-6">
      <h1 class="text-xl font-bold text-gray-900 mb-1">Résultats</h1>
      <p class="text-gray-500 text-sm">
        <%= @analysis.comments_array.size %> commentaires récupérés •
        <a href="<%= @analysis.video_url %>" target="_blank" class="text-red-600 hover:underline">Voir la vidéo</a>
      </p>
    </div>

    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="font-semibold text-gray-700 mb-4">Commentaires bruts</h2>
      <ul class="space-y-3">
        <% @analysis.comments_array.each do |comment| %>
          <li class="border-b border-gray-100 pb-3 text-sm text-gray-700"><%= comment %></li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
