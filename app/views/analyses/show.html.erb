<div class="min-h-screen bg-blush relative overflow-hidden">

  <!-- Blobs -->
  <div class="blob" style="background-color: hsl(215,60%,78%); width:280px; height:280px; top:-80px; left:-80px;"></div>
  <div class="blob" style="background-color: hsl(12,70%,75%); width:300px; height:300px; top:-100px; right:-100px;"></div>
  <div class="blob" style="background-color: hsl(12,70%,75%); width:280px; height:280px; bottom:-100px; left:-80px;"></div>
  <div class="blob" style="background-color: hsl(215,60%,78%); width:260px; height:260px; bottom:-80px; right:-80px;"></div>

  <!-- Header -->
  <header class="relative z-10 max-w-4xl mx-auto px-6 pt-6 pb-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <%= link_to analyses_path, class: "text-sm font-medium text-coral-deep hover:opacity-80 flex items-center gap-1" do %>
        ← New analysis
      <% end %>
      <%= link_to "History", analyses_path, class: "text-sm text-muted-soft hover:text-coral-deep" %>
    </div>
  </header>

  <main class="relative z-10 max-w-4xl mx-auto px-6 pb-16 space-y-5">

    <!-- Video card -->
    <section class="bg-white rounded-3xl p-6 shadow-sm border border-soft">
      <div class="flex gap-5 items-center">
        <% if @analysis.video_thumbnail.present? %>
          <img src="<%= @analysis.video_thumbnail %>" alt="thumbnail"
               class="w-28 h-20 rounded-2xl object-cover shrink-0">
        <% end %>
        <div class="flex-1 min-w-0">
          <h2 class="text-xl leading-tight mb-2">
            <%= @analysis.video_title.presence || "Analysis Results" %>
          </h2>
          <p class="text-sm text-muted-soft flex flex-wrap items-center gap-x-2">
            <% if @analysis.channel_name.present? %>
              <span><%= @analysis.channel_name %></span>
              <span>·</span>
            <% end %>
            <span><%= @analysis.comments_array.size %> comments analyzed</span>
            <span>·</span>
            <a href="<%= @analysis.video_url %>" target="_blank" class="text-coral-deep hover:opacity-80">
              View video ↗
            </a>
          </p>
        </div>
      </div>
    </section>

    <% ai = @analysis.ai_analysis_hash %>

    <% if ai.present? %>

      <!-- Executive Summary -->
      <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
        <h3 class="text-2xl mb-3">Executive Summary</h3>
        <p class="text-muted-soft leading-relaxed"><%= ai["summary"] %></p>
      </section>

      <!-- Recommended Actions -->
      <% if ai["recommended_actions"].present? %>
        <%
          groups = {
            "sprint_1"     => "Immediate Priorities — Sprint 1",
            "sprint_2"     => "Quick Wins — Sprint 2",
            "strategic"    => "Strategic Initiatives",
            "deprioritize" => "Deprioritize"
          }
          actions_by_group = ai["recommended_actions"].group_by { |a| a["group"] || "sprint_1" }
        %>
        <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
          <h3 class="text-2xl mb-5">Recommended Actions</h3>
          <% groups.each do |key, label| %>
            <% group_actions = actions_by_group[key]; next if group_actions.blank? %>
            <div class="mb-5">
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-soft mb-3"><%= label %></p>
              <div class="space-y-3">
                <% group_actions.each do |action| %>
                  <%
                    badge_class = case action["priority"]
                      when "high"   then "bg-red-50 text-red-700 border-red-200"
                      when "medium" then "bg-yellow-50 text-yellow-700 border-yellow-200"
                      else               "bg-gray-50 text-gray-500 border-gray-200"
                    end
                  %>
                  <div class="rounded-2xl border border-soft p-4">
                    <div class="flex justify-between items-start gap-4 mb-1">
                      <p class="font-semibold text-base" style="font-family:'Outfit',sans-serif; color:hsl(240,35%,25%)"><%= action["action"] %></p>
                      <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full border <%= badge_class %>">
                        <%= action["priority"]&.upcase %>
                      </span>
                    </div>
                    <p class="text-sm text-muted-soft mb-2"><%= action["rationale"] %></p>
                    <div class="flex flex-wrap gap-3 text-xs text-muted-soft">
                      <% if action["team"].present? %><span>👥 <%= action["team"] %></span><% end %>
                      <% if action["timeline"].present? %><span>⏱️ <%= action["timeline"] %></span><% end %>
                      <% if action["success_metric"].present? %><span>📈 <%= action["success_metric"] %></span><% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <!-- Sentiment -->
      <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
        <h3 class="text-2xl mb-5">Overall Sentiment</h3>
        <div class="grid grid-cols-3 gap-3">
          <div class="rounded-2xl p-5 text-center bg-green-50">
            <p class="text-3xl font-bold text-green-700"><%= ai.dig("sentiment","positive") %>%</p>
            <p class="text-xs uppercase tracking-wider mt-1 text-green-600 opacity-80">Positive</p>
          </div>
          <div class="rounded-2xl p-5 text-center bg-muted-soft" style="background-color:hsl(12,40%,90%)">
            <p class="text-3xl font-bold text-muted-soft"><%= ai.dig("sentiment","neutral") %>%</p>
            <p class="text-xs uppercase tracking-wider mt-1 text-muted-soft opacity-80">Neutral</p>
          </div>
          <div class="rounded-2xl p-5 text-center" style="background-color:hsl(350,75%,55%,0.1)">
            <p class="text-3xl font-bold text-coral-deep"><%= ai.dig("sentiment","negative") %>%</p>
            <p class="text-xs uppercase tracking-wider mt-1 text-coral-deep opacity-80">Negative</p>
          </div>
        </div>
      </section>

      <!-- Pain Points -->
      <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
        <h3 class="text-2xl mb-5">Top Pain Points</h3>
        <div class="divide-y" style="border-color:hsl(12,40%,88%)">
          <% ai["pain_points"]&.each_with_index do |point, i| %>
            <%
              impact = point["business_impact"].to_s.upcase
              severity = point["severity"].to_i
              impact_class = impact == "HIGH" ? "bg-red-50 text-red-700 border-red-200" : impact == "MEDIUM" ? "bg-yellow-50 text-yellow-700 border-yellow-200" : "bg-gray-50 text-gray-500 border-gray-200"
            %>
            <div class="py-5 first:pt-0 last:pb-0">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h4 class="font-semibold text-lg leading-snug" style="font-family:'Outfit',sans-serif; color:hsl(240,35%,25%)">#<%= i+1 %> <%= point["title"] %></h4>
                <div class="flex items-center gap-2 shrink-0">
                  <% if impact.present? %>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border <%= impact_class %>"><%= impact %></span>
                  <% end %>
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full border text-coral-deep" style="background-color:hsl(350,75%,55%,0.08); border-color:hsl(350,75%,55%,0.3)">
                    <%= point["percentage"] %>% · <%= point["count"] %> mentions
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 mb-2 text-sm text-muted-soft">
                <% flames = [(severity / 2.0).ceil, 5].min %>
                <% flames.times do %><span class="text-orange-400 text-xs">🔥</span><% end %>
                <span class="text-xs"><%= severity %>/10 severity</span>
              </div>

              <p class="text-sm text-muted-soft leading-relaxed mb-3"><%= point["description"] %></p>

              <% if point["verbatims"].present? %>
                <div class="space-y-1.5 mb-3">
                  <% point["verbatims"].each do |q| %>
                    <p class="text-xs text-muted-soft italic border-l-2 pl-3" style="border-color:hsl(12,40%,88%)">"<%= q %>"</p>
                  <% end %>
                </div>
              <% end %>

              <% if point["recommended_action"].present? %>
                <div class="rounded-xl px-3 py-2 text-xs" style="background-color:hsl(12,40%,90%); color:hsl(240,35%,35%)">
                  <span class="font-semibold">Action →</span> <%= point["recommended_action"] %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <!-- Feature Requests -->
      <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
        <h3 class="text-2xl mb-5">Feature Requests</h3>
        <div class="divide-y" style="border-color:hsl(12,40%,88%)">
          <% ai["feature_requests"]&.each do |req| %>
            <div class="py-5 first:pt-0 last:pb-0">
              <div class="flex items-start justify-between gap-4 mb-1.5 flex-wrap">
                <h4 class="font-semibold text-lg leading-snug" style="font-family:'Outfit',sans-serif; color:hsl(240,35%,25%)"><%= req["title"] %></h4>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full border text-lavender" style="background-color:hsl(230,70%,65%,0.12); border-color:hsl(230,70%,65%,0.3)">
                    <%= req["percentage"] %>% · <%= req["votes"] %> votes
                  </span>
                  <% tag_class = req["priority"] == "Critical" ? "bg-red-50 text-red-700 border-red-200" : req["priority"] == "Quick Win" ? "bg-emerald-50 text-emerald-700 border-emerald-200" : "bg-gray-50 text-gray-500 border-gray-200" %>
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full border <%= tag_class %>"><%= req["priority"] %></span>
                </div>
              </div>
              <p class="text-sm text-muted-soft leading-relaxed mb-1.5"><%= req["description"] %></p>
              <p class="text-xs text-muted-soft">
                <%= req["sentiment"] == "positive" ? "😊" : "😤" %>
                <%= req["sentiment"]&.capitalize %> sentiment
              </p>
            </div>
          <% end %>
        </div>
      </section>

    <% end %>

    <!-- Raw Comments -->
    <section class="bg-white rounded-3xl p-7 shadow-sm border border-soft">
      <h3 class="text-2xl mb-5">Raw Comments (<%= @analysis.comments_array.size %>)</h3>
      <div class="divide-y" style="border-color:hsl(12,40%,88%)" data-comments-target="list">
        <% @analysis.comments_texts.first(8).each do |comment| %>
          <p class="py-3.5 text-sm leading-relaxed" style="color:hsl(240,35%,25%)"><%= comment %></p>
        <% end %>
        <% if @analysis.comments_texts.size > 8 %>
          <div id="more-comments" class="hidden">
            <% @analysis.comments_texts.drop(8).each do |comment| %>
              <p class="py-3.5 text-sm leading-relaxed" style="color:hsl(240,35%,25%)"><%= comment %></p>
            <% end %>
          </div>
          <button onclick="document.getElementById('more-comments').classList.toggle('hidden'); this.textContent = this.textContent.includes('more') ? 'Show less ↑' : 'Show more comments ↓'"
                  class="mt-4 text-sm font-medium text-coral-deep hover:opacity-80">
            Show more comments ↓
          </button>
        <% end %>
      </div>
    </section>

  </main>
</div>
