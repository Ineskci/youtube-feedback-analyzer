# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore environment variables
.env
.env.local

# Ignore database files
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-*

# Ignore node modules
/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore Mac files
.DS_Store

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
